<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ========================= -->
    <!-- CARD PRINCIPAL -->
    <!-- ========================= -->

    <style name="DashboardCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">22dp</item>
        <item name="cardElevation">3dp</item>
        <item name="cardBackgroundColor">@color/cardColor</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- Card with rounded top corners for bottom sheet look -->
    <style name="CardConEsquinasSuperiores" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/cardColor</item>
        <item name="cardElevation">4dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.App.Card.TopRounded</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="ShapeAppearance.App.Card.TopRounded" parent="">
        <item name="cornerSizeTopLeft">32dp</item>
        <item name="cornerSizeTopRight">32dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="EsquinasSuperiores" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- ========================= -->
    <!-- INPUTS -->
    <!-- ========================= -->

    <style name="LoginTextInputLayout"
        parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="boxStrokeColor">@color/primaryColor</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxBackgroundColor">@color/cardColor</item>
        <item name="hintTextColor">@color/textSecondary</item>
    </style>

    <!-- ========================= -->
    <!-- BOTONES -->
    <!-- ========================= -->

    <style name="InvenzoButton"
        parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/primaryColor</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:paddingVertical">14dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
        <item name="fontFamily">sans-serif-medium</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- ========================= -->
    <!-- BOTTOM NAVIGATION STYLE -->
    <!-- ========================= -->

    <style name="Widget.App.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/navBackground</item>
        <item name="itemIconTint">@color/nav_item_color_state</item>
        <item name="itemTextColor">@color/nav_item_color_state</item>
        <item name="itemActiveIndicatorStyle">@style/App.TopLineIndicator</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemRippleColor">@android:color/transparent</item>
    </style>

    <style name="App.TopLineIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/navIndicator</item>
        <item name="android:width">40dp</item>
        <item name="android:height">3dp</item>
    </style>

    <!-- ========================= -->
    <!-- TITULOS -->
    <!-- ========================= -->

    <style name="DashboardTitle">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="SectionTitle">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="DashboardSubtitle">
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="DashboardBigNumber">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">30sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-black</item>
    </style>

    <style name="circleImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">32dp</item>
    </style>

    <style name="Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/grayBorder</item>
    </style>

</resources>